# Datawrapper
DW_API_TOKEN=your-datawrapper-api-token
DW_FOLDER=123456
DW_FOLDER_UKRAINE_MAPS=113965

# DeepL
DEEPL_TOKEN=your-deepl-api-token
DEEPL_ENDPOINT=https://api-free.deepl.com/v2/translate
MAX_LINE_LENGTH=18

# Slack
SLACK_HOOK_TECHNICAL=https://hooks.slack.com/services/xxx
SLACK_HOOK_GENERAL=https://hooks.slack.com/services/xxx

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
SPREADSHEET_ID=your-spreadsheet-id
SPREADSHEET_RANGE_WITH_HEADER=dw-map-markers!A2:H100
SPREADSHEET_RANGE_NO_HEADER=dw-map-markers!A3:H100

# Server
PORT=3000
